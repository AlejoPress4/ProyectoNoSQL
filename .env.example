# MongoDB Atlas Configuration
MONGODB_URI=mongodb+srv://tech_rag_admin:<password>@tech-rag-cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=tech_rag_db

# LLM API Configuration (Groq)
GROQ_API_KEY=your_groq_api_key_here

# Embedding Models
TEXT_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
IMAGE_EMBEDDING_MODEL=openai/clip-vit-base-patch32

# Data Sources
DEVTO_API_KEY=optional_devto_api_key
UNSPLASH_API_KEY=optional_unsplash_api_key

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
